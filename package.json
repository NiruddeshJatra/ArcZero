{
  "name": "arczero",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "yarn generate-og && yarn generate-favicons && vite build",
    "build:portal": "yarn generate-og && yarn generate-favicons && vite build --mode portal",
    "generate-og": "yarn node scripts/generate-og.mjs",
    "generate-favicons": "yarn node scripts/generate-favicons.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.47.0",
    "eslint": "^9.9.0",
    "happy-dom": "^15.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.3.0",
    "sharp": "^0.33.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
